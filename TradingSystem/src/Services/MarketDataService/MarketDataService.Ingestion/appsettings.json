{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "IngestionSettings": {
    "Transport": {
      "Type": "Websocket",
      "BaseUrl": "wss://fstream.binance.com"
    },
    "Destination": {
      "Type": "Kafka",
      "Connection":  "localhost:29092"
    },
    
    "Streams": [
      {
        "Name": "Candles",
        "Route": "/market/ws",
        "Parameters": "/ubusdt@kline_1m"
      },
      {
        "Name": "Trades",
        "Route": "/public/ws",
        "Parameters": "/ubusdt@trade"
      },
      {
        "Name": "AggregateTrades",
        "Route": "/market/ws",
        "Parameters": "/ubusdt@aggTrade"
      },
      {
        "Name": "Orderbook",
        "Route": "/public/ws",
        "Parameters": "/ubusdt@depth20@500ms"
      },
      {
        "Name": "Liquidations",
        "Route": "/market/ws",
        "Parameters": "/ubusdt@forceOrder"
      }
    ]
  }
}
