{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "IngestionSettings": {
    "Transport": {
      "Type": "Websocket",
      "BaseUrl": "wss://fstream.binance.com"
    },
    "Destination": {
      "Type": "RabbitMQ",
      "Connection": "amqp://admin:admin123@localhost:5672/"
    },
    
    "Streams": [
      {
        "Name": "Candles",
        "Route": "/market/ws",
        "Parameters": "/ensousdt@kline_1m"
      },
      {
        "Name": "Trades",
        "Route": "/public/ws",
        "Parameters": "/ensousdt@trade"
      },
      {
        "Name": "AggregateTrades",
        "Route": "/market/ws",
        "Parameters": "/ensousdt@aggTrade"
      },
      {
        "Name": "Orderbook",
        "Route": "/public/ws",
        "Parameters": "/ensousdt@depth20@500ms"
      },
      {
        "Name": "Liquidations",
        "Route": "/market/ws",
        "Parameters": "/ensousdt@forceOrder"
      }
    ]
  }
}
