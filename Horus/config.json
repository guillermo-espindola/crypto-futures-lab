{
  "market": {
    "symbol": "VELVETUSDT",
    "timeframe": "1m",
    "timeframes": ["1m"],
    "max_candles": 250,
    "max_agg_trades": 1000,
    "max_liquidations": 100,
    "max_trades": 1000
  },

  "portfolio": {
    "initial_balance": 100.0
  },

  "risk": {
    "max_risk_per_trade": 0.010,
    "max_leverage": 10,
    "max_drawdown": 0.20,
    "max_total_exposure": 0.3
    },

  "regime":{
    "default_period": 14
  },

  "structure":{
    "swing_window": 5
  },

  "scoring": {
    "ema_alpha": 0.35,
    "confirmation_threshold": 1,
    "long_bias_weight": 0.65,
    "flow_weight": 0.25,
    "regime_weight": 0.10,
    "book_weight": 0.15
  },

  "liquidity": {
    "lookback_period": 20,
    "sweep_sensitivity": 0.6
  },

  "order_flow": {
    "window_size": 30,
    "impact_sensitivity": 1.2
  },

  "execution": {
    "slippage_factor": 0.001,
    "latency_ms": 30,
    "taker_fee": 0.0005
  },
  
  "behavior": {
    "allow_more_trades": true,
    "cooldown_seconds": 3,
    "noise_tolerance": "high"
  },
  "kafka": {
    "bootstrap_server": "localhost:29092",
    "topics": [ "Candles", "Trades", "Orderbook", "Liquidations", "AggregateTrades"],
    "group_id": "horus-engine"
  },
  "logger": {
    "enable_file_logging": true,
    "enable_console_logging": true
  },
  "telegram":{
    "token": "{TOKEN}",
    "chat_id": "{CHAT_ID}",
    "api_url": "https://api.telegram.org/bot{TOKEN}/sendMessage"
  }
}
