{
  "market": {
    "symbol": "REUSDT",
    "timeframe": "5s",
    "timeframes": [],
    "timeframe_seconds": 5,    
    "timer_seconds": 5,
    "max_candles": 500,
    "max_agg_trades": 1000,
    "max_liquidations": 100,
    "max_trades": 100,
    "max_orderbook_depth": 100
  },
  "history": {
    "candles_endpoint": "https://fapi.binance.com/fapi/v1/klines",
    "orderbook_depth_endpoint": "https://fapi.binance.com/fapi/v1/depth",
    "aggregate_trades_endpoint": "https://fapi.binance.com/fapi/v1/aggTrades"
  },

  "portfolio": {
    "initial_balance": 100.0
  },

  "risk": {
    "max_risk_per_trade": 0.010,
    "max_leverage": 10,
    "max_drawdown": 0.20,
    "max_total_exposure": 0.3
    },

  "regime":{
    "default_period": 14
  },

  "structure":{
    "swing_window": 10
  },

  "scoring": {
    "ema_alpha": 0.35,
    "confirmation_threshold": 1,
    "long_bias_weight": 0.65,
    "flow_weight": 0.25,
    "regime_weight": 0.10,
    "book_weight": 0.15
  },

  "liquidity": {
    "lookback_period": 20,
    "sweep_sensitivity": 0.6
  },

  "order_flow": {
    "window_size": 30,
    "impact_sensitivity": 1.2
  },

  "execution": {
    "slippage_factor": 0.001,
    "latency_ms": 30,
    "taker_fee": 0.0005
  },
  
  "behavior": {
    "allow_more_trades": true,
    "cooldown_seconds": 3,
    "noise_tolerance": "high"
  },
  "consumer": {
    "id": "horus",
    "type": "RabbitMQ",
    "connection_string": "amqp://admin:admin123@localhost:5672/",
    "sources": [ "Candles", "Trades", "Orderbook", "Liquidations", "AggregateTrades"]
  },
  "logger": {
    "enable_file_logging": true,
    "enable_console_logging": true
  },
  "telegram":{
    "token": "{TOKEN}",
    "chat_id": "{CHAT_ID}",
    "api_url": "https://api.telegram.org/bot{TOKEN}/sendMessage"
  }
}
